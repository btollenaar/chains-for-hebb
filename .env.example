APP_NAME="Chains for Hebb"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://bentollenaar.dev/chains-for-hebb

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production: LOG_LEVEL=warning

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=chains_for_hebb
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (development — logs emails instead of sending)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@chainsforhebb.org"
MAIL_FROM_NAME="${APP_NAME}"

# Production SMTP example:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=your_username
# MAIL_PASSWORD=your_password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@chainsforhebb.org"

# Stripe (use test keys for development — SEPARATE account from PrintStore)
STRIPE_KEY=pk_test_your_publishable_key
STRIPE_SECRET=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Newsletter batch sending
# NEWSLETTER_BATCH_SIZE=100
# NEWSLETTER_BATCH_DELAY=60

# Fulfillment: Printful (SEPARATE store from PrintStore)
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=
PRINTFUL_WEBHOOK_SECRET=

# Fundraising
FUNDRAISING_GOAL=15000.00
ORG_NAME="Chains for Hebb"
DONATIONS_TAX_DEDUCTIBLE=true

# Google Analytics 4
GOOGLE_ANALYTICS_ID=

# Meta/Facebook Pixel
META_PIXEL_ID=

VITE_APP_NAME="${APP_NAME}"
