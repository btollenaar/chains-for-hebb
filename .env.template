# =============================================================================
# Laravel 11 Business Management Platform - Environment Configuration Template
# =============================================================================
#
# This is a comprehensive template for configuring a new instance of the
# platform. Copy this file to .env and customize the values for your business.
#
# Quick Start:
#   1. Copy this file: cp .env.template .env
#   2. Generate app key: php artisan key:generate
#   3. Configure database settings (see section 11)
#   4. Configure Stripe keys (test or live) (see section 13)
#   5. Customize business profile and branding (sections 2-4)
#   6. Run migrations: php artisan migrate
#   7. Seed database: php artisan db:seed
#
# =============================================================================

# -----------------------------------------------------------------------------
# 1. APPLICATION SETTINGS
# -----------------------------------------------------------------------------

APP_NAME="Northwind Supply & Services"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/New_York
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# -----------------------------------------------------------------------------
# 2. BUSINESS PROFILE
# -----------------------------------------------------------------------------
# Configure your business type and core information

BUSINESS_TYPE=hybrid
# Options: wellness, retail, salon, restaurant, fitness, professional, services, hybrid

BUSINESS_NAME="Northwind Supply & Services"
BUSINESS_TAGLINE="Quality widgets, reliable bookings."
BUSINESS_INDUSTRY=retail_services

# -----------------------------------------------------------------------------
# 3. BUSINESS TERMINOLOGY
# -----------------------------------------------------------------------------
# Customize entity names to match your business (e.g., "Treatments" instead
# of "Services", "Clients" instead of "Customers", etc.)

# Product Terminology
TERM_PRODUCT_SINGULAR=Widget
TERM_PRODUCT_PLURAL=Widgets

# Service Terminology
TERM_SERVICE_SINGULAR=Service
TERM_SERVICE_PLURAL=Services

# Appointment Terminology
TERM_APPOINTMENT_SINGULAR=Booking
TERM_APPOINTMENT_PLURAL=Bookings

# Customer Terminology
TERM_CUSTOMER_SINGULAR=Customer
TERM_CUSTOMER_PLURAL=Customers

# Provider/Staff Terminology
TERM_PROVIDER_SINGULAR="Staff Member"
TERM_PROVIDER_PLURAL="Staff Members"
TERM_TEAM=Staff

# -----------------------------------------------------------------------------
# 4. BRANDING & ASSETS
# -----------------------------------------------------------------------------
# Configure logos, favicons, and brand assets

BRANDING_LOGO_PATH=images/logo.png
BRANDING_LOGO_ALT="Business Logo"
BRANDING_FAVICON=favicon.ico
BRANDING_HERO_VIDEO=

# If using hero video, provide full URL (e.g., https://player.vimeo.com/video/123456789)

# -----------------------------------------------------------------------------
# 5. THEME CONFIGURATION
# -----------------------------------------------------------------------------
# Customize colors and fonts for your brand

# Brand Colors (hex format)
THEME_PRIMARY_COLOR=#2E2A25
THEME_SECONDARY_COLOR=#6B5F4A
THEME_ACCENT_COLOR=#D77F48

# Typography
THEME_PRIMARY_FONT="Work Sans"
THEME_HEADING_FONT="Playfair Display"

# -----------------------------------------------------------------------------
# 6. SOCIAL MEDIA LINKS
# -----------------------------------------------------------------------------
# Leave empty to hide social media icons

SOCIAL_FACEBOOK=
SOCIAL_INSTAGRAM=
SOCIAL_TWITTER=
SOCIAL_LINKEDIN=
SOCIAL_GOOGLE_MAPS=

# Example values:
# SOCIAL_FACEBOOK=https://www.facebook.com/yourpage
# SOCIAL_INSTAGRAM=https://www.instagram.com/yourhandle
# SOCIAL_GOOGLE_MAPS=https://goo.gl/maps/yourlink

# -----------------------------------------------------------------------------
# 7. OWNER/ABOUT INFORMATION
# -----------------------------------------------------------------------------
# Configure business owner or key team member information

OWNER_NAME=
OWNER_TITLE=
OWNER_CREDENTIALS=
OWNER_BIO=
OWNER_PHOTO=

# Example values:
# OWNER_NAME="Jane Smith"
# OWNER_TITLE="Founder & CEO"
# OWNER_CREDENTIALS="MBA, PMP"
# OWNER_BIO="With over 20 years of experience in retail and service delivery..."
# OWNER_PHOTO=images/owner.jpg

# -----------------------------------------------------------------------------
# 8. HOMEPAGE CONTENT
# -----------------------------------------------------------------------------
# Customize homepage text and messaging

HOME_HERO_HEADING="Reliable products. Ready-to-book services."
HOME_HERO_SUBHEADING="Quality widgets, reliable bookings."
HOME_ABOUT_HEADING="About Northwind"
HOME_ABOUT_TEXT="We supply dependable products and on-site services with a team of dedicated staff members."

# -----------------------------------------------------------------------------
# 9. CONTACT INFORMATION
# -----------------------------------------------------------------------------

BUSINESS_EMAIL=info@yourbusiness.com
BUSINESS_PHONE=555-123-4567

BUSINESS_ADDRESS_STREET="123 Main Street"
BUSINESS_ADDRESS_CITY="Anytown"
BUSINESS_ADDRESS_STATE=FL
BUSINESS_ADDRESS_ZIP=12345
BUSINESS_ADDRESS_COUNTRY=USA

# -----------------------------------------------------------------------------
# 10. FEATURE TOGGLES
# -----------------------------------------------------------------------------
# Enable or disable specific features

FEATURE_PRODUCTS=true
FEATURE_SERVICES=true
FEATURE_APPOINTMENTS=true
FEATURE_MEMBERSHIPS=false
FEATURE_GIFT_CARDS=true
FEATURE_BLOG=true
FEATURE_REVIEWS=true
FEATURE_LOYALTY=false
FEATURE_MULTI_LOCATION=false

# -----------------------------------------------------------------------------
# 11. DATABASE CONFIGURATION
# -----------------------------------------------------------------------------

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel_business
DB_USERNAME=root
DB_PASSWORD=

# DreamHost Shared Hosting Configuration:
# -----------------------------------------
# 1. Create database in DreamHost panel (example: username_dbname)
# 2. Note the MySQL hostname (usually: mysql.yourdomain.com)
# 3. Update settings below:
#
# DB_HOST=mysql.yourdomain.com
# DB_DATABASE=yourusername_dbname
# DB_USERNAME=yourusername_dbuser
# DB_PASSWORD=your_secure_password
#
# Important for DreamHost:
# - Database name format: username_databasename
# - Use MySQL hostname from panel, NOT 127.0.0.1
# - Ensure database user has ALL PRIVILEGES on the database

# -----------------------------------------------------------------------------
# 12. SESSION & CACHE
# -----------------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# -----------------------------------------------------------------------------
# 13. STRIPE PAYMENT CONFIGURATION
# -----------------------------------------------------------------------------

# Test Mode Keys (use these for development/testing)
STRIPE_KEY=pk_test_YOUR_TEST_KEY_HERE
STRIPE_SECRET=sk_test_YOUR_TEST_SECRET_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Production Keys (uncomment and use these for live site)
# STRIPE_KEY=pk_live_YOUR_LIVE_KEY_HERE
# STRIPE_SECRET=sk_live_YOUR_LIVE_SECRET_HERE
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_LIVE_WEBHOOK_SECRET_HERE

# Payment Settings
PAYMENT_CURRENCY=USD
TAX_RATE=0.07

# Test Credit Cards (Stripe test mode):
# Success: 4242 4242 4242 4242
# Declined: 4000 0000 0000 0002
# Requires Authentication: 4000 0027 6000 3184

# Stripe Webhook Setup (DreamHost):
# ----------------------------------
# 1. In Stripe Dashboard, go to Developers > Webhooks
# 2. Add endpoint: https://yourdomain.com/stripe/webhook
# 3. Select events: checkout.session.completed, payment_intent.succeeded, payment_intent.payment_failed
# 4. Copy webhook signing secret to STRIPE_WEBHOOK_SECRET above

# -----------------------------------------------------------------------------
# 14. EMAIL CONFIGURATION
# -----------------------------------------------------------------------------

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@yourbusiness.com"
MAIL_FROM_NAME="${APP_NAME}"

# For production, configure with your email provider:
#
# DreamHost SMTP:
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.dreamhost.com
#   MAIL_PORT=587
#   MAIL_USERNAME=noreply@yourdomain.com
#   MAIL_PASSWORD=your-email-password
#   MAIL_ENCRYPTION=tls
#
# SendGrid (Recommended):
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.sendgrid.net
#   MAIL_PORT=587
#   MAIL_USERNAME=apikey
#   MAIL_PASSWORD=your-sendgrid-api-key
#   MAIL_ENCRYPTION=tls
#
# Mailgun:
#   MAIL_MAILER=mailgun
#   MAILGUN_DOMAIN=mg.yourdomain.com
#   MAILGUN_SECRET=your-mailgun-api-key
#   MAILGUN_ENDPOINT=api.mailgun.net

# -----------------------------------------------------------------------------
# 15. LOGGING
# -----------------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Production Logging (DreamHost):
# --------------------------------
# For production, use 'daily' to rotate logs and prevent disk space issues:
# LOG_CHANNEL=daily
# LOG_LEVEL=error

# -----------------------------------------------------------------------------
# 16. THIRD-PARTY SERVICES (Optional)
# -----------------------------------------------------------------------------

# AWS S3 (if using for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher (if using real-time features)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Vite (asset building)
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
#
# Important Notes:
#
# 1. Security:
#    - NEVER commit .env file to version control
#    - Keep production credentials secure
#    - Use strong, unique APP_KEY (generated by php artisan key:generate)
#    - Use different database credentials for each environment
#    - Store backup of production .env securely offline
#
# 2. Production Deployment (DreamHost):
#    - Set APP_ENV=production and APP_DEBUG=false
#    - Use APP_URL=https://yourdomain.com (HTTPS required)
#    - Configure real email service (SMTP or SendGrid)
#    - Enable Stripe live mode with production keys
#    - Set up database with correct DreamHost hostname
#    - Configure webhook URL in Stripe dashboard
#    - Set LOG_CHANNEL=daily to rotate logs
#    - Test all payment flows before going live
#
# 3. DreamHost-Specific Requirements:
#    - PHP version: 8.2 or higher (set in panel)
#    - Enable OPcache for better performance
#    - Use MySQL hostname from panel (not localhost/127.0.0.1)
#    - Database name must use username_ prefix
#    - Public directory must be set to /public
#    - Ensure storage/ and bootstrap/cache/ are writable
#    - Set up cron job for Laravel scheduler if using features
#
# 4. Testing:
#    - Use Stripe test keys for development
#    - Use MAIL_MAILER=log to avoid sending real emails locally
#    - Test with different BUSINESS_TYPE values to see UI changes
#    - Test terminology changes by modifying TERM_* values
#    - Run php artisan migrate:fresh --seed for test data
#
# 5. Support & Documentation:
#    - See README.md for complete setup instructions
#    - See DEPLOYMENT-GUIDE.md for DreamHost deployment walkthrough
#    - See CUSTOMIZATION-GUIDE.md for business customization options
#    - See TEST-CREDENTIALS.md for test account information
#
# =============================================================================
